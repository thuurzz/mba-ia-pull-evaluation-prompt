# LangSmith Configuration
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=

# Para descobrir seu username: publique qualquer prompt no LangSmith Hub, depois abra-o e clique no ícone de cadeado (🔒) para ver seu username.
USERNAME_LANGSMITH_HUB=

# OpenAI Configuration
OPENAI_API_KEY=

# Google Gemini Configuration
GOOGLE_API_KEY=

# Ollama Local Configuration
OLLAMA_BASE_URL=http://localhost:11434

# LLM Configuration
# --- Opção 1: Ollama Local (custo zero, iterações ilimitadas) ---
LLM_PROVIDER=ollama
LLM_MODEL=gemma4:12b
EVAL_MODEL=gemma4:12b

# --- Opção 2: Google Gemini ---
# LLM_PROVIDER=google
# LLM_MODEL=gemini-2.5-flash
# EVAL_MODEL=gemini-2.5-flash

# --- Opção 3: OpenAI ---
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
# EVAL_MODEL=gpt-4o
